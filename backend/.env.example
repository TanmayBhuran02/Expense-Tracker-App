# Database connection URL (PostgreSQL format)
DATABASE_URL=postgresql://username:password@localhost:5432/dbname

# Flask secret key for session signing
SECRET_KEY=replace-with-a-secure-random-secret-key-in-production

# JWT secret key for access token signing
JWT_SECRET_KEY=replace-with-another-secure-random-secret-key-in-production

# Frontend URL (required for CORS in production)
# FRONTEND_URL=https://your-frontend-domain.com

# Flask Environment configuration
# FLASK_ENV=production
